generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model business {
  id             String   @id
  name           String
  sessionId      String
  selected       Boolean  @default(true)
  adAccountCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  session        session  @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "Business_sessionId_fkey")

  @@index([sessionId], map: "Business_sessionId_idx")
}

model session {
  id          String     @id
  userId      String
  userName    String
  token       String     @db.Text
  appId       String
  ip          String?
  userAgent   String?    @db.Text
  lastLoginAt DateTime?
  cookies     String?    @db.LongText
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  business    business[]

  @@unique([userId, appId], map: "Session_userId_appId_key")
  @@index([userId], map: "Session_userId_idx")
}
